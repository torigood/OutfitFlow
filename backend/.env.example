# Cloudinary Config (이미지 업로드/삭제)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=your_upload_preset
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# OpenRouter AI Config
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=llama-2-vision

# OpenWeatherMap Config
OPENWEATHER_API_KEY=your_openweather_api_key

# OpenRouter 모델 선택 (기본값: llama-2-vision 무료)
# 무료 모델: llama-2-vision, mistral-7b
# 가성비 모델: claude-3-5-sonnet (권장)
# 최고 성능: gpt-4-vision, openrouter/auto
OPENROUTER_MODEL=

# OpenWeatherMap Config
# OpenWeatherMap 홈페이지에서 가입 후 API 키 생성
OPENWEATHER_API_KEY=