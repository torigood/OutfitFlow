# OpenRouter AI Config
# https://openrouter.ai/keys 에서 API 키 생성
OPENROUTER_API_KEY=sk-or-your-api-key-here

# OpenRouter 모델 선택 (기본값: llama-2-vision 무료)
# 무료 모델: llama-2-vision, mistral-7b
# 가성비 모델: claude-3-5-sonnet (권장)
# 최고 성능: gpt-4-vision, openrouter/auto
OPENROUTER_MODEL=llama-2-vision

# OpenWeatherMap
OPENWEATHER_API_KEY=your_openweather_api_key

# Cloudinary (signed delete용 - Dashboard > Settings > Access Keys)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
