# Firebase Config
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id
FIREBASE_WEB_CLIENT_ID=your_web_client_id_here

# Google Web Client ID for React Native
GOOGLE_WEB_CLIENT_ID=your_google_client_id_here

# Naver Config
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# Backend API URL
RAILWAY_BACKEND_URL=http://localhost:8000

# ============================================
# Backend Configuration
# ============================================
# Railway Backend URL (배포 후 입력)
# 예: https://outfitflow-api-production.railway.app
RAILWAY_BACKEND_URL=http://localhost:8000

# Backend API Keys (backend/.env 파일 참조)
# OpenRouter AI Config - backend/.env.example 참조
# https://openrouter.ai/keys 에서 API 키 생성
